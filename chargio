#!/bin/bash
# Start/stop helper for Chargio

set -e

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
APP_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"

PID_FILE="$APP_DIR/.battery.pid"
PORT="${CHARGIO_PORT:-7943}"
URL="http://127.0.0.1:$PORT"
INSTALL_DIR="${CHARGIO_INSTALL_DIR:-$HOME/.local/bin}"
INSTALL_PATH="$INSTALL_DIR/chargio"

is_running() {
  [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

case "${1:-start}" in
  start)
    if is_running; then
      echo "Already running (PID $(cat "$PID_FILE"))"
      if [ "$2" = "--open" ]; then
        open "$URL"
      fi
      exit 0
    fi
    python3 "$APP_DIR/chargio.py" --port "$PORT" > /dev/null 2>&1 &
    echo $! > "$PID_FILE"
    echo "Started (PID $!) -> $URL"
    if [ "$2" = "--open" ]; then
      open "$URL"
    fi
    ;;
  stop)
    if [ ! -f "$PID_FILE" ]; then
      echo "Not running"
      exit 1
    fi
    PID=$(cat "$PID_FILE")
    if kill "$PID" 2>/dev/null; then
      rm -f "$PID_FILE"
      echo "Stopped (PID $PID)"
    else
      rm -f "$PID_FILE"
      echo "Process $PID already gone"
    fi
    ;;
  kill)
    if [ ! -f "$PID_FILE" ]; then
      echo "Not running"
      exit 1
    fi
    PID=$(cat "$PID_FILE")
    if kill -9 "$PID" 2>/dev/null; then
      rm -f "$PID_FILE"
      echo "Killed (PID $PID)"
    else
      rm -f "$PID_FILE"
      echo "Process $PID already gone"
    fi
    ;;
  restart)
    "$0" stop >/dev/null 2>&1 || true
    "$0" start "$2"
    ;;
  open)
    if ! is_running; then
      "$0" start
    fi
    open "$URL"
    ;;
  status)
    if is_running; then
      echo "Running (PID $(cat "$PID_FILE"))"
    else
      rm -f "$PID_FILE" 2>/dev/null
      echo "Not running"
    fi
    ;;
  install-cli)
    mkdir -p "$INSTALL_DIR"
    ln -sf "$APP_DIR/chargio" "$INSTALL_PATH"
    echo "Installed $INSTALL_PATH -> $APP_DIR/chargio"
    case ":$PATH:" in
      *":$INSTALL_DIR:"*) ;;
      *)
        echo "Add this to your shell profile if needed:"
        echo "  export PATH=\"$INSTALL_DIR:\$PATH\""
        ;;
    esac
    ;;
  uninstall-cli)
    if [ -L "$INSTALL_PATH" ] && [ "$(readlink "$INSTALL_PATH")" = "$APP_DIR/chargio" ]; then
      rm "$INSTALL_PATH"
      echo "Removed $INSTALL_PATH"
    else
      echo "No Chargio symlink found at $INSTALL_PATH"
    fi
    ;;
  *)
    echo "Usage: $0 {start|stop|kill|restart|status|open|install-cli|uninstall-cli} [--open]"
    exit 1
    ;;
esac
